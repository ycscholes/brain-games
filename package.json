{
  "name": "cici-brain-training",
  "version": "1.0.0",
  "private": true,
  "description": "教育工具",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "Sass",
    "framework": "React"
  },
  "scripts": {
    "lint": "npm run lint:code && npm run lint:rules",
    "lint:code": "eslint src config .trae/rules --max-warnings=0",
    "lint:rules": "find src -name '*.ts' -o -name '*.tsx' | while read file; do node .trae/rules/project_rules_validator.js \"$file\" \"no-explicit-any\" || exit 1; node .trae/rules/project_rules_validator.js \"$file\" \"async-try-catch\" || exit 1; done",
    "secrets:check": "bash scripts/check-secrets.sh",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "build:weapp": "taro build --type weapp --no-check",
    "build:h5": "taro build --type h5",
    "build:ci": "npm run build:weapp",
    "assets:check": "bash scripts/sync-cloudbase-images.sh --check",
    "assets:upload": "bash scripts/sync-cloudbase-images.sh --upload",
    "deploy:cloudfunctions": "bash scripts/deploy-cloudfunctions.sh",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "postinstall": "weapp-tw patch",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "author": "",
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@tarojs/components": "^4.1.11",
    "@tarojs/helper": "^4.1.11",
    "@tarojs/plugin-framework-react": "^4.1.11",
    "@tarojs/plugin-html": "^4.1.11",
    "@tarojs/plugin-platform-h5": "^4.1.11",
    "@tarojs/plugin-platform-weapp": "^4.1.11",
    "@tarojs/react": "^4.1.11",
    "@tarojs/runtime": "^4.1.11",
    "@tarojs/shared": "^4.1.11",
    "@tarojs/taro": "^4.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@tarojs/cli": "^4.1.11",
    "@tarojs/taro-loader": "^4.1.11",
    "@tarojs/webpack5-runner": "^4.1.11",
    "@types/node": "^25.2.3",
    "@types/react": "^18.3.12",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "autoprefixer": "^10.4.24",
    "babel-preset-taro": "^4.1.11",
    "eslint": "^8.57.0",
    "eslint-config-taro": "^4.1.11",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "postcss": "^8.5.6",
    "sass": "^1.97.3",
    "tailwindcss": "^4.1.18",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.9.3",
    "weapp-tailwindcss": "^4.9.8",
    "webpack": "5.91.0"
  }
}
